# Database
DATABASE_URL=postgresql://smartweb:smartweb_dev_pass@postgres:5432/smartweb_db

# Security (CHANGE IN PRODUCTION!)
SECRET_KEY=dev-secret-key-change-in-production-min-32-chars-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Seed Configuration
ALLOW_DB_RESET=true
AUTO_SEED=true
SEED_GROUPS=100
SEED_TAXPAYERS=1500
SEED_BOS=300
SEED_RNG=20260109

# Logging
LOG_LEVEL=INFO

# API
API_V1_PREFIX=/api/v1
PROJECT_NAME=SmartWeb - Wajib Pajak Grup
